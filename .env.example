VALOR_PORT=3200
VALOR_DB_PATH=./data/valor.db
LOG_LEVEL=info
VALOR_AGENT_KEY=
# Set to true only for local/test workflows that intentionally allow header auth without VALOR_AGENT_KEY.
VALOR_ALLOW_ROLE_HEADER_FALLBACK=false

# Database backend: sqlite (default, zero setup) or postgres (production/scale)
DB_BACKEND=sqlite
# DB_POSTGRES_URL=postgresql://user:pass@localhost:5432/valor
# DB_POSTGRES_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

# Provider: Anthropic Claude API
ANTHROPIC_API_KEY=

# Provider: Ollama (local models - works with bare Ollama or any Ollama-compatible proxy)
OLLAMA_BASE_URL=http://starbase:40114
# OLLAMA_STATUS_URL=http://starbase:40114/api/tags

# MCP server (agent communication via Model Context Protocol)
# MCP is mounted at /mcp on the same port as the REST API.
# Agents authenticate with VALOR_AGENT_KEY during MCP initialize handshake.
# No additional configuration needed — MCP starts automatically.

# Comma-separated gate names to disable. Leave blank to keep all gates enabled.
DISABLED_GATES=


# ── Claude Code Operative Integration ──────────────────────────────
# These are used by the Stop hook (scripts/valor-checkin.ts) and the
# valor-operative skill to identify this Claude Code instance to VALOR.
# Set these when running Claude Code as a VALOR operative.
VALOR_CALLSIGN=gage
VALOR_AGENT_ID=
# VALOR_URL defaults to http://localhost:3200 if not set
# VALOR_AGENT_KEY is shared with the engine — same key as above
