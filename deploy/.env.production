# VALOR Engine — Production Environment
# Copy to project root as .env and fill in real values.
# DO NOT commit this file with real secrets.

# ── Core ────────────────────────────────────────────────────────────────────
VALOR_PORT=3200
VALOR_DB_PATH=/data/valor.db
LOG_LEVEL=info
NODE_ENV=production

# Agent authentication key — required for production.
# Generate with: openssl rand -hex 32
VALOR_AGENT_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Do not allow unauthenticated role headers in production.
VALOR_ALLOW_ROLE_HEADER_FALLBACK=false

# ── Database ────────────────────────────────────────────────────────────────
# sqlite (default, zero setup) or postgres (production/scale)
DB_BACKEND=sqlite
# DB_POSTGRES_URL=postgresql://user:pass@localhost:5432/valor

# ── NATS Event Bus ──────────────────────────────────────────────────────────
# In Docker Compose this is overridden to nats://nats:4222
NATS_URL=nats://localhost:4222

# ── Provider: Anthropic Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Provider: Ollama (local models) ─────────────────────────────────────────
# Point to your Ollama instance. Works with bare Ollama or any compatible proxy.
OLLAMA_BASE_URL=http://starbase:40114
# OLLAMA_STATUS_URL=http://starbase:40114/api/tags

# ── Director LLM Service ───────────────────────────────────────────────────
DIRECTOR_MODEL=gemma3:27b
DIRECTOR_GEAR2_MODEL=nemotron-cascade-2:latest
DIRECTOR_CONFIDENCE_THRESHOLD=5

# ── SIGINT Callback ─────────────────────────────────────────────────────────
SIGINT_URL=http://localhost:8082

# ── Gate Control ────────────────────────────────────────────────────────────
# Comma-separated gate names to disable. Leave blank to keep all gates enabled.
DISABLED_GATES=

# ── Telegram Gateway (optional) ────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# PRINCIPAL_TELEGRAM_ID=8551062231
