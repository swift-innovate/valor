{
  "name": "valor-engine",
  "version": "0.1.0",
  "description": "VALOR — Unified Agent Orchestration Engine",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "director": "node --import tsx scripts/director-service.ts",
    "director:start": "node --import tsx src/director/service.ts",
    "director:dev": "tsx watch scripts/director-service.ts",
    "director:test": "node --import tsx scripts/test-director-llm.ts",
    "director:smoke": "node --import tsx scripts/smoke-director.ts",
    "inject": "node --import tsx scripts/inject-mission.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/nats-core": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "better-sqlite3": "^11.7.0",
    "codex": "^0.2.3",
    "grammy": "^1.41.1",
    "hono": "^4.7.0",
    "nanoid": "^5.0.9",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "engram": ">=0.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
